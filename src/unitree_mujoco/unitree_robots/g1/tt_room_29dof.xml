<mujoco model="g1_29dof_tt_room">
  <include file="g1_29dof.xml"/>

  <statistic center="0 0 0.8" extent="8.0"/>

  <visual>
    <headlight diffuse="0.65 0.65 0.65" ambient="0.35 0.35 0.35" specular="0 0 0"/>
    <rgba haze="0.12 0.16 0.20 1"/>
    <global azimuth="-135" elevation="-25"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.32 0.45 0.56" rgb2="0.04 0.05 0.06" width="512" height="3072"/>
    <texture type="2d" name="tt_floor_tex" builtin="checker" mark="edge"
      rgb1="0.30 0.34 0.36" rgb2="0.20 0.24 0.26" markrgb="0.65 0.68 0.70"
      width="360" height="360"/>
    <material name="tt_floor" texture="tt_floor_tex" texuniform="true" texrepeat="10 8" reflectance="0.15"/>
    <material name="tt_wall" rgba="0.72 0.72 0.68 1"/>
    <material name="mat_table_surface" rgba="0.12 0.45 0.12 1"/>
    <material name="mat_table_line" rgba="1 1 1 1"/>
    <material name="mat_table_leg" rgba="0.55 0.35 0.1 1"/>
    <material name="mat_net" rgba="0.9 0.9 0.9 0.8"/>
  </asset>

  <worldbody>
    <light name="main_light" pos="0 0 4.0" dir="0 0 -1" directional="true"/>
    <light name="table_light" pos="2.0 0 3.0" dir="0 0 -1" diffuse="0.45 0.45 0.42"/>
    <geom name="floor" type="plane" size="0 0 0.05" material="tt_floor"/>

    <!-- Room footprint 11m x 8m, identical to vln_apartment_29dof.xml outer walls. -->
    <geom name="wall_north" type="box" size="5.5 0.06 1.15" pos="0 4.0 1.15" material="tt_wall"/>
    <geom name="wall_south" type="box" size="5.5 0.06 1.15" pos="0 -4.0 1.15" material="tt_wall"/>
    <geom name="wall_west" type="box" size="0.06 4.0 1.15" pos="-5.5 0 1.15" material="tt_wall"/>
    <geom name="wall_east" type="box" size="0.06 4.0 1.15" pos="5.5 0 1.15" material="tt_wall"/>

    <!-- Ping-pong table, ITTF standard: 2.74 x 1.525 m, top at z=0.760, thickness 0.038.
         Geometry copied from TTRL-ICRA2026 pingpong_only.xml, translated so the table
         center sits at x=+2.0: the robot spawns at the origin, 0.63 m behind the near
         baseline (x = 2.0 - 1.37 = 0.63). -->
    <geom name="table_surface" type="box"
          pos="2.0 0 0.741"
          size="1.37 0.7625 0.019"
          material="mat_table_surface"
          friction="0.35 0.005 0.0001"
          solimp="0.97 0.99 0.001" solref="0.002 1"/>

    <!-- White boundary lines: visual only, no collision. -->
    <geom name="line_long_left" type="box" pos="2.0 0.7475 0.761" size="1.37 0.015 0.001"
          contype="0" conaffinity="0" material="mat_table_line"/>
    <geom name="line_long_right" type="box" pos="2.0 -0.7475 0.761" size="1.37 0.015 0.001"
          contype="0" conaffinity="0" material="mat_table_line"/>
    <geom name="line_short_far" type="box" pos="3.36 0 0.761" size="0.015 0.7625 0.001"
          contype="0" conaffinity="0" material="mat_table_line"/>
    <geom name="line_short_near" type="box" pos="0.64 0 0.761" size="0.015 0.7625 0.001"
          contype="0" conaffinity="0" material="mat_table_line"/>
    <geom name="line_center_y" type="box" pos="2.0 0 0.761" size="1.37 0.008 0.001"
          contype="0" conaffinity="0" material="mat_table_line"/>
    <geom name="line_center_x" type="box" pos="2.0 0 0.761" size="0.008 0.7625 0.001"
          contype="0" conaffinity="0" material="mat_table_line"/>

    <!-- Table legs: ground to table underside (z = 0 ~ 0.722). -->
    <geom name="leg_fl" type="cylinder" pos="3.1 0.65 0.361" size="0.04 0.361"
          material="mat_table_leg" friction="0.6 0.005 0.001"
          solimp="0.99 0.99 0.001" solref="0.01 1"/>
    <geom name="leg_fr" type="cylinder" pos="3.1 -0.65 0.361" size="0.04 0.361"
          material="mat_table_leg" friction="0.6 0.005 0.001"
          solimp="0.99 0.99 0.001" solref="0.01 1"/>
    <geom name="leg_bl" type="cylinder" pos="0.9 0.65 0.361" size="0.04 0.361"
          material="mat_table_leg" friction="0.6 0.005 0.001"
          solimp="0.99 0.99 0.001" solref="0.01 1"/>
    <geom name="leg_br" type="cylinder" pos="0.9 -0.65 0.361" size="0.04 0.361"
          material="mat_table_leg" friction="0.6 0.005 0.001"
          solimp="0.99 0.99 0.001" solref="0.01 1"/>

    <!-- Net: 0.1525 m tall, top at z = 0.9125. Posts and top bar are visual only;
         the net face collides. -->
    <geom name="net_post_left" type="cylinder" pos="2.0 0.79 0.836" size="0.01 0.07625"
          material="mat_net" contype="0" conaffinity="0"/>
    <geom name="net_post_right" type="cylinder" pos="2.0 -0.79 0.836" size="0.01 0.07625"
          material="mat_net" contype="0" conaffinity="0"/>
    <geom name="net_top_bar" type="cylinder" pos="2.0 0 0.9125" size="0.005 0.79"
          quat="0.7071068 0.7071068 0 0"
          material="mat_net" contype="0" conaffinity="0"/>
    <geom name="net_face" type="box" pos="2.0 0 0.836" size="0.003 0.7625 0.07625"
          material="mat_net"
          friction="0.1 0.001 0.0001"
          solimp="0.5 0.7 0.01" solref="0.01 1"/>
  </worldbody>
</mujoco>
